{
    "name": "@diia-inhouse/utils",
    "version": "6.0.55",
    "type": "module",
    "description": "Generic utils",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "repository": "https://github.com/diia-open-source/be-pkg-utils",
    "author": "Diia",
    "license": "SEE LICENSE IN LICENSE.md",
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "tsdown",
        "semantic-release": "semantic-release",
        "lint": "oxlint && oxfmt --check .",
        "lint-fix": "oxlint --fix && oxfmt .",
        "lint:lockfile": "lockfile-lint --path package-lock.json --allowed-hosts registry.npmjs.org --validate-https",
        "prepare": "npm run build",
        "test": "tsc --project tests/tsconfig.json --noEmit && vitest run",
        "test:watch": "vitest watch",
        "find-circulars": "madge --circular --extensions ts ./"
    },
    "dependencies": {
        "@diia-inhouse/design-system": "4.17.1",
        "@types/luxon": "3.7.1",
        "bson": "7.2.0",
        "compare-versions": "6.1.1",
        "fast-levenshtein": "3.0.0",
        "lodash": "4.18.1",
        "luxon": "3.7.2",
        "map-age-cleaner": "0.2.0",
        "moment": "2.30.1",
        "type-fest": "5.6.0"
    },
    "peerDependencies": {
        "@diia-inhouse/errors": ">=2.0.0",
        "@diia-inhouse/types": ">=13.1.0",
        "@diia-inhouse/validators": ">=2.0.0",
        "@slack/types": ">=2.0.0"
    },
    "peerDependenciesMeta": {
        "@slack/types": {
            "optional": true
        }
    },
    "devDependencies": {
        "@diia-inhouse/configs": "7.0.1",
        "@diia-inhouse/errors": "2.2.7",
        "@diia-inhouse/oxc-config": "1.11.0",
        "@diia-inhouse/test": "8.2.22",
        "@diia-inhouse/types": "14.2.1",
        "@diia-inhouse/validators": "2.2.43",
        "@slack/types": "2.21.1",
        "@types/fast-levenshtein": "0.0.4",
        "@types/lodash": "4.17.24",
        "@types/node": "25.6.2",
        "@vitest/coverage-v8": "4.1.5",
        "@vitest/ui": "4.1.5",
        "lockfile-lint": "5.0.0",
        "madge": "8.0.0",
        "oxfmt": "0.48.0",
        "oxlint": "1.63.0",
        "oxlint-tsgolint": "0.22.1",
        "protobufjs": "8.6.0",
        "rimraf": "6.1.3",
        "tsdown": "0.22.0",
        "typescript": "5.9.3",
        "vite-tsconfig-paths": "6.1.1",
        "vitest": "4.1.5"
    },
    "release": {
        "extends": "@diia-inhouse/configs/dist/semantic-release/package"
    },
    "commitlint": {
        "extends": "@diia-inhouse/configs/dist/commitlint"
    },
    "madge": {
        "tsConfig": "./tsconfig.json"
    }
}
