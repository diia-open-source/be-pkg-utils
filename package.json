{
    "name": "@diia-inhouse/utils",
    "version": "5.3.22",
    "description": "Generic utils",
    "main": "dist/index.js",
    "types": "dist/types/index.d.ts",
    "repository": "https://github.com/diia-open-source/be-pkg-utils",
    "author": "Diia",
    "license": "SEE LICENSE IN LICENSE.md",
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "tsc",
        "semantic-release": "semantic-release",
        "lint": "eslint . && prettier --check .",
        "lint-fix": "eslint --fix . && prettier --write .",
        "lint:lockfile": "lockfile-lint --path package-lock.json --allowed-hosts registry.npmjs.org --validate-https",
        "prepare": "npm run build",
        "test": "tsc --project tests/tsconfig.json --noEmit && vitest run",
        "test:watch": "vitest watch",
        "find-circulars": "madge --circular --extensions ts ./"
    },
    "dependencies": {
        "@diia-inhouse/design-system": "3.27.0",
        "@types/luxon": "3.7.1",
        "bson": "7.2.0",
        "compare-versions": "6.1.1",
        "design-system": "2.5.0",
        "fast-levenshtein": "3.0.0",
        "lodash": "4.18.1",
        "luxon": "3.7.2",
        "map-age-cleaner": "0.2.0",
        "moment": "2.30.1",
        "type-fest": "4.41.0"
    },
    "peerDependencies": {
        "@diia-inhouse/errors": ">=1.4.1",
        "@diia-inhouse/types": ">=4.4.1",
        "@diia-inhouse/validators": ">=1.5.0"
    },
    "devDependencies": {
        "@diia-inhouse/configs": "6.1.1",
        "@diia-inhouse/errors": "1.18.19",
        "@diia-inhouse/eslint-config": "8.8.0",
        "@diia-inhouse/test": "7.3.18",
        "@diia-inhouse/types": "12.0.1",
        "@diia-inhouse/validators": "1.28.29",
        "@slack/types": "2.20.0",
        "@types/fast-levenshtein": "0.0.4",
        "@types/lodash": "4.17.24",
        "@types/node": "25.3.3",
        "@vitest/coverage-v8": "4.0.18",
        "@vitest/ui": "4.0.18",
        "eslint": "9.39.3",
        "lockfile-lint": "4.14.1",
        "madge": "8.0.0",
        "protobufjs": "7.5.5",
        "rimraf": "6.1.3",
        "typescript": "5.9.3",
        "vite-tsconfig-paths": "6.1.1",
        "vitest": "4.0.18"
    },
    "release": {
        "extends": "@diia-inhouse/configs/dist/semantic-release/package"
    },
    "commitlint": {
        "extends": "@diia-inhouse/configs/dist/commitlint"
    },
    "prettier": "@diia-inhouse/eslint-config/prettier",
    "madge": {
        "tsConfig": "./tsconfig.json"
    }
}
